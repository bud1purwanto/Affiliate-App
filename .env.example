# ====== Threadsmil environment ======

# Port server (Railway akan mengisi otomatis)
PORT=3000

# ---- OpenRouter (AI generator UTAS) ----
# Daftar & ambil key di https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model default (bisa dioverride per-request dari UI). Contoh model yang bagus:
#   openrouter/auto            <- otomatis pilih model terbaik per prompt
#   anthropic/claude-3.5-sonnet
#   openai/gpt-4o-mini
#   google/gemini-flash-1.5
#   meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openrouter/auto
# Dipakai OpenRouter untuk atribusi (opsional)
OPENROUTER_REFERER=https://threadsmil.app
OPENROUTER_TITLE=Threadsmil

# ---- Shopee Affiliate Open API ----
# Ambil App ID & Secret di https://affiliate.shopee.co.id/ (menu Open API)
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
SHOPEE_API_URL=https://open-api.affiliate.shopee.co.id/graphql

# ---- Setup Wizard (opsional, disarankan saat deploy publik) ----
# Jika diisi, halaman /setup.html & endpoint /api/setup butuh token ini.
SETUP_TOKEN=

# ---- Threads (opsional, posting via API resmi Meta) ----
# Hanya dibutuhkan jika ingin auto-post dari Web App. Untuk Chrome Extension
# tidak perlu karena posting lewat DOM threads.com.
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
